AIRTABLE_PAT=your_token_here
AIRTABLE_WORKSPACE_ID=your_wsp_id_here
# Optional comma-separated filter if you only want selected Airtable bases.
AIRTABLE_BASE_IDS=

BASEROW_URL=your_url_here
BASEROW_WORKSPACE_ID=id_number

# Required for schema management (workspaces/applications/tables/fields) and file uploads.
BASEROW_MANAGEMENT_TOKEN=your_management_token_here
# Must be either "Token" (Baserow Personal API Token) or "JWT" (User JWT access token).
BASEROW_MANAGEMENT_TOKEN_TYPE=Token

# Optional. Used for row create/update APIs; if blank, management token is reused.
BASEROW_DATABASE_TOKEN=

# Optional. JWT refresh token from /api/user/token-auth/. When provided, the script
# will automatically refresh an expired JWT access token instead of failing.
BASEROW_REFRESH_TOKEN=

# Max number of times the script will refresh an expired JWT during a single run.
MAX_TOKEN_REFRESHES=3

SQLITE_PATH=id_mapping.db
ATTACHMENTS_DIR=attachments_cache
REQUEST_TIMEOUT_SECONDS=60
BATCH_SIZE=50
DRY_RUN=false
REPORT_PATH=migration_report.json
